{
  "name": "postcss-rtlcss-playground",
  "version": "1.0.0",
  "description": "PostCSS plugin to build Cascading Style Sheets (CSS) with Left-To-Right (LTR) and Right-To-Left (RTL) rules",
  "keywords": [
    "postcss",
    "css",
    "postcss-plugin",
    "rtl",
    "ltr",
    "right-to-left",
    "left-to-right",
    "postcss-rtlcss",
    "rtlcss"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.tsx\"",
    "generate-types": "typed-scss-modules src --aliasPrefixes.@constants src/constants",
    "generate-types:dev": "typed-scss-modules src --aliasPrefixes.@constants src/constants --watch",
    "start": "pnpm generate-types:dev & webpack serve --open --config webpack.dev-config.js",
    "build": "pnpm generate-types && webpack --config webpack.config.js"
  },
  "author": "ElChiniNet",
  "license": "Apache-2.0",
  "dependencies": {
    "monaco-editor": "^0.55.1",
    "postcss": "^8.4.31",
    "postcss-rtlcss": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-github-btn": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "classnames": "^2.5.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-utils": "^3.0.0",
    "file-loader": "^6.2.0",
    "globals": "^17.5.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "postcss-loader": "^8.2.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "browserslist": [
    "defaults"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": "=1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "dompurify@<3.3.2": ">=3.3.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "lodash@<=4.17.23": ">=4.18.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "picomatch@<2.3.2": "=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "serialize-javascript@<7.0.5": ">=7.0.5"      
    }
  }
}
