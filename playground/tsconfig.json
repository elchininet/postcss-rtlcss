{
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": "../docs/",
    "module": "esnext",
    "jsx": "react",
    "target": "es6",
    "moduleResolution": "bundler",
    "declaration": false,
    "noImplicitAny": true,
    "removeComments": true,
    "rootDir": "./",
    "types": ["node"],
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "paths": {
      "@root": ["../../src"],
      "@types": ["./src/@types"],
      "@constants": ["./src/constants"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utilities/*": ["./src/utilities/*"],
      "@icons/*": ["./src/icons/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
  